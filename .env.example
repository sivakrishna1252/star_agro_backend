# PostgreSQL
# Local Docker: DB_HOST=db and run `docker compose --profile local-db up -d --build`
# External/production DB: set DB_HOST to the remote server IP/hostname (no local-db profile)
DB_HOST=db
DB_PORT=5432
DB_NAME=star_agro
DB_USER=postgres
DB_PASSWORD=change-me-strong-password

# Django
SECRET_KEY=change-me-to-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,star-api.aspune.cloud
CSRF_TRUSTED_ORIGINS=https://star-api.aspune.cloud
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# App
APP_PORT=6021
SERVE_MEDIA=true
GUNICORN_WORKERS=3

# First-run bootstrap (set false after initial deploy)
CREATE_SUPERUSER=true
SEED_DATA=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_EMAIL=admin@example.com
